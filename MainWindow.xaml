<Window x:Class="TemizlikMasaUygulamasi.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Temizlik ve Bakım Merkezi Professional"
        Height="900"
        Width="1450"
        MinHeight="760"
        MinWidth="1180"
        Loaded="Window_Loaded"
        PreviewKeyDown="Window_PreviewKeyDown"
        PreviewKeyUp="Window_PreviewKeyUp"
        KeyDown="Window_KeyDown"
        FontSize="18"
        FontFamily="Segoe UI"
        AutomationProperties.Name="Temizlik ve Bakım Merkezi Professional penceresi"
        AutomationProperties.HelpText="Alt menü tabanlı, erişilebilir ve gelişmiş bakım uygulaması.">
    <Window.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F6F8FC" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="PanelBrush" Color="#E8EDF8" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#111111" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#1F2937" />
        <SolidColorBrush x:Key="AccentBrush" Color="#004A7C" />
        <SolidColorBrush x:Key="AccentTextBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="BorderBrushStrong" Color="#314158" />

        <Style TargetType="Border">
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushStrong}" />
            <Setter Property="BorderThickness" Value="1.5" />
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushStrong}" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="MinHeight" Value="42" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushStrong}" />
            <Setter Property="BorderThickness" Value="1.5" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushStrong}" />
            <Setter Property="BorderThickness" Value="1.5" />
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushStrong}" />
            <Setter Property="BorderThickness" Value="1.5" />
        </Style>
    </Window.Resources>
    <Grid x:Name="RootGrid" Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border x:Name="HeaderBorder" Grid.Row="0" CornerRadius="14" Padding="14" Margin="0,0,0,10">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Temizlik ve Bakım Merkezi Professional"
                               FontSize="34"
                               FontWeight="Bold"
                               AutomationProperties.Name="Uygulama başlığı" />
                    <TextBlock x:Name="HeaderVersionText"
                               Margin="0,2,0,0"
                               FontWeight="SemiBold"
                               Text="Sürüm" />
                    <TextBlock x:Name="ThemeStateText"
                               Margin="0,2,0,0"
                               FontWeight="SemiBold"
                               Text="Tema: Aydınlık" />
                    <TextBlock x:Name="HeaderSubtitleText"
                               Margin="0,4,0,0"
                               TextWrapping="Wrap"
                               Text="Vedat Güldü tarafından, Olcay Aşçı anısına profesyonel bakım platformu olarak geliştirilmiştir."
                               AutomationProperties.Name="Başlık açıklaması" />
                    <TextBlock x:Name="TributeBannerText"
                               Margin="0,6,0,0"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               AutomationProperties.Name="İthaf satırı" />
                </StackPanel>

                <WrapPanel DockPanel.Dock="Right" VerticalAlignment="Top" ItemHeight="42" ItemWidth="210">
                    <Button x:Name="RunAsAdminButton"
                            Content="_Yönetici Modu"
                            Margin="0,0,8,0"
                            Padding="8"
                            Click="RunAsAdminButton_Click" />
                    <Button x:Name="ToggleFullScreenButton"
                            Content="_Tam Ekran (F11)"
                            Padding="8"
                            Click="ToggleFullScreenButton_Click" />
                </WrapPanel>
            </DockPanel>
        </Border>

        <Border x:Name="ClassicMenuBorder" Grid.Row="1" CornerRadius="10" Padding="4" Margin="0,0,0,10">
            <Menu x:Name="MainMenu"
                  Background="Transparent"
                  IsTabStop="False"
                  KeyboardNavigation.TabNavigation="None"
                  KeyboardNavigation.ControlTabNavigation="None">
                <MenuItem Header="_Uygulama">
                    <MenuItem Header="_Ana Sayfa" Tag="Dashboard" Click="MenuNavigate_Click" />
                    <MenuItem Header="A_yarlar">
                        <MenuItem x:Name="SettingsThemeLightMenuItem" Header="_Aydınlık Tema" IsCheckable="True" Click="ApplyLightTheme_Click" />
                        <MenuItem x:Name="SettingsThemeDarkMenuItem" Header="_Karanlık Tema" IsCheckable="True" Click="ApplyDarkTheme_Click" />
                        <Separator />
                        <MenuItem x:Name="SettingsHighContrastMenuItem" Header="_Yüksek Kontrast (Sadece Uygulama)" IsCheckable="True" Click="ToggleHighContrastFromMenu_Click" />
                        <MenuItem x:Name="SettingsStartupTipsMenuItem" Header="_Başlangıç İpuçlarını Göster" IsCheckable="True" Click="ToggleStartupTipsFromMenu_Click" />
                    </MenuItem>
                    <MenuItem Header="_Güncelleme Denetle" Click="CheckUpdatesNow_Click" />
                    <Separator />
                    <MenuItem Header="_Çıkış" Click="MenuExit_Click" />
                </MenuItem>
                <MenuItem Header="_Modüller">
                    <MenuItem Header="_Temizlik" Tag="Clean" Click="MenuNavigate_Click" />
                    <MenuItem Header="S_istem" Tag="System" Click="MenuNavigate_Click" />
                    <MenuItem Header="_Raporlar" Tag="Reports" Click="MenuNavigate_Click" />
                    <MenuItem Header="Erişile_bilirlik" Tag="Accessibility" Click="MenuNavigate_Click" />
                    <MenuItem Header="İt_haf" Tag="Tribute" Click="MenuNavigate_Click" />
                    <MenuItem Header="_V3 Özellikler" Tag="Pro" Click="MenuNavigate_Click" />
                </MenuItem>
                <MenuItem Header="_Görünüm">
                    <MenuItem Header="_Tam Ekran (F11)" Click="ToggleFullScreenButton_Click" />
                </MenuItem>
                <MenuItem Header="_Yardım">
                    <MenuItem Header="_Kaynakları Aç" Click="OpenSelectedSource_Click" />
                </MenuItem>
            </Menu>
        </Border>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border x:Name="ModuleShellBorder" Grid.Row="0" Visibility="Collapsed" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                <DockPanel LastChildFill="True">
                    <Button x:Name="BackToDashboardButton"
                            DockPanel.Dock="Left"
                            Width="180"
                            Content="_Geri Dön"
                            Click="BackToDashboardButton_Click"
                            AutomationProperties.Name="Ana sayfaya geri dön" />
                    <TextBlock x:Name="ModuleShellTitleText"
                               Margin="14,0,0,0"
                               VerticalAlignment="Center"
                               FontSize="22"
                               FontWeight="Bold"
                               Text="Modül" />
                </DockPanel>
            </Border>

            <Border x:Name="DashboardPanel" Grid.Row="1" CornerRadius="12" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*" />
                        <ColumnDefinition Width="2*" />
                    </Grid.ColumnDefinitions>

                    <Border x:Name="DashboardHeroBorder" Grid.Row="0" Grid.ColumnSpan="2" CornerRadius="10" Padding="16" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Temiz Ana Ekran" FontSize="30" FontWeight="Bold" />
                            <TextBlock Margin="0,8,0,0" TextWrapping="Wrap"
                                       Text="Ana ekran sade tutuldu. Alt tuşu ile üstteki klasik menüyü açarak veya alttaki menüden modüllere ulaşabilirsiniz." />
                            <WrapPanel Margin="0,12,0,0" ItemHeight="42" ItemWidth="240">
                                <Button Content="_Önerilen Bakımı Başlat" Margin="0,0,8,8" Click="StartRecommendedFromDashboard_Click" />
                                <Button Content="_Son Rapor Klasörünü Aç" Margin="0,0,8,8" Click="OpenReportsFolder_Click" />
                                <Button Content="_Güncelleme Denetle" Margin="0,0,8,8" Click="CheckUpdatesNow_Click" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border x:Name="DashboardStatusBorder" Grid.Row="1" Grid.Column="0" CornerRadius="10" Padding="16" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="Canlı Durum Özeti" FontSize="24" FontWeight="Bold" />
                            <TextBlock x:Name="DashboardThemeText" Margin="0,10,0,4" FontWeight="SemiBold" />
                            <TextBlock x:Name="DashboardScheduleStateText" Margin="0,2,0,4" FontWeight="SemiBold" />
                            <TextBlock x:Name="DashboardLastStatusText" Margin="0,2,0,4" FontWeight="SemiBold" TextWrapping="Wrap" />
                            <TextBlock x:Name="DashboardUpdateStateText" Margin="0,2,0,4" FontWeight="SemiBold" TextWrapping="Wrap" />
                            <TextBlock x:Name="DashboardLastReportText" Margin="0,2,0,8" TextWrapping="Wrap" />
                            <TextBlock Text="Alt menü erişim ipucu: Alt tuşuna basınca harf kısayolları görünür." TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border x:Name="DashboardQuickActionsBorder" Grid.Row="1" Grid.Column="1" CornerRadius="10" Padding="16" Margin="8,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Hızlı Geçişler" FontSize="24" FontWeight="Bold" />
                            <WrapPanel Margin="0,10,0,0" ItemHeight="42" ItemWidth="220">
                                <Button Content="_Temizlik Modülü" Tag="Clean" Margin="0,0,8,8" Click="NavigateButton_Click" />
                                <Button Content="S_istem Modülü" Tag="System" Margin="0,0,8,8" Click="NavigateButton_Click" />
                                <Button Content="_Raporlar Modülü" Tag="Reports" Margin="0,0,8,8" Click="NavigateButton_Click" />
                                <Button Content="Erişile_bilirlik" Tag="Accessibility" Margin="0,0,8,8" Click="NavigateButton_Click" />
                                <Button Content="İt_haf Modülü" Tag="Tribute" Margin="0,0,8,8" Click="NavigateButton_Click" />
                                <Button Content="_V3 Özellikler" Tag="Pro" Margin="0,0,8,8" Click="NavigateButton_Click" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border x:Name="CleanPanel" Grid.Row="1" Visibility="Collapsed" CornerRadius="12" Padding="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="3*" />
                    </Grid.ColumnDefinitions>

                    <Border x:Name="TasksBorder" Grid.Column="0" CornerRadius="10" Padding="14" Margin="0,0,8,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="Temizlik Görevleri" FontSize="24" FontWeight="Bold" />

                            <ScrollViewer Grid.Row="1" Margin="0,10,0,10" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <CheckBox x:Name="TaskUserTemp" Margin="0,5" IsChecked="True" Content="Kullanıcı geçici dosyalarını temizle" />
                                    <CheckBox x:Name="TaskWindowsTemp" Margin="0,5" IsChecked="True" Content="Windows temp klasörünü temizle (yönetici gerekir)" />
                                    <CheckBox x:Name="TaskRecycleBin" Margin="0,5" IsChecked="True" Content="Geri dönüşüm kutusunu boşalt" />
                                    <CheckBox x:Name="TaskDns" Margin="0,5" IsChecked="True" Content="DNS önbelleğini sıfırla" />
                                    <CheckBox x:Name="TaskNetworkRefresh" Margin="0,5" IsChecked="False" Content="Ağ bağdaştırıcılarını yenile" />
                                    <CheckBox x:Name="TaskResetUpdate" Margin="0,5" IsChecked="False" Content="Windows Update bileşenlerini sıfırla" />
                                    <CheckBox x:Name="TaskBrowserCache" Margin="0,5" IsChecked="False" Content="Tarayıcı önbelleklerini temizle" />
                                </StackPanel>
                            </ScrollViewer>

                            <WrapPanel Grid.Row="2" ItemHeight="42" ItemWidth="210">
                                <Button Content="_Önerilen Seçimler" Margin="0,0,8,0" Padding="8" Click="SelectRecommended_Click" />
                                <Button Content="_Tümünü Seç" Margin="0,0,8,0" Padding="8" Click="SelectAll_Click" />
                                <Button Content="T_ümünü Kaldır" Margin="0,0,8,0" Padding="8" Click="ClearAll_Click" />
                            </WrapPanel>
                        </Grid>
                    </Border>

                    <Border x:Name="LogBorder" Grid.Column="1" CornerRadius="10" Padding="14" Margin="8,0,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="Canlı İşlem Günlüğü" FontSize="24" FontWeight="Bold" />

                            <TextBox x:Name="LogBox"
                                     Grid.Row="1"
                                     Margin="0,10,0,10"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     TextWrapping="Wrap"
                                     FontFamily="Consolas"
                                     FontSize="16"
                                     AutomationProperties.Name="Canlı günlük" />

                            <WrapPanel Grid.Row="2" ItemHeight="44" ItemWidth="215">
                                <Button x:Name="StartButton" Content="_Temizliği Başlat" Margin="0,0,8,0" Padding="8" Click="StartButton_Click" />
                                <Button x:Name="CancelButton" Content="_Durdur" Margin="0,0,8,0" Padding="8" IsEnabled="False" Click="CancelButton_Click" />
                                <Button x:Name="SaveLogButton" Content="_Logu Kaydet" Margin="0,0,8,0" Padding="8" Click="SaveLogButton_Click" />
                                <Button x:Name="SaveJsonReportButton" Content="_JSON Raporu" Padding="8" Click="SaveJsonReportButton_Click" />
                            </WrapPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border x:Name="SystemPanel" Grid.Row="1" Visibility="Collapsed" CornerRadius="12" Padding="12">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border x:Name="ToolsBorder" CornerRadius="10" Padding="14" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="Sistem Araçları" FontSize="24" FontWeight="Bold" />
                                <WrapPanel Margin="0,10,0,0" ItemHeight="42" ItemWidth="240">
                                    <Button Content="_Sistem Özeti" Margin="0,0,8,8" Padding="8" Click="CreateSystemSnapshot_Click" />
                                    <Button Content="S_FC Doğrulama" Margin="0,0,8,8" Padding="8" Click="RunSfcVerify_Click" />
                                    <Button Content="_DISM Sağlık Kontrolü" Margin="0,0,8,8" Padding="8" Click="RunDismCheckHealth_Click" />
                                    <Button Content="_Kullanıcı Temp Aç" Margin="0,0,8,8" Padding="8" Click="OpenUserTempFolder_Click" />
                                    <Button Content="_Rapor Klasörü Aç" Margin="0,0,8,8" Padding="8" Click="OpenReportsFolder_Click" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border x:Name="SchedulerBorder" CornerRadius="10" Padding="14" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="Günlük Otomatik Çalıştırma" FontSize="24" FontWeight="Bold" />
                                <WrapPanel Margin="0,10,0,0" ItemHeight="42">
                                    <TextBlock Text="Saat:" VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <ComboBox x:Name="ScheduleHourBox" Width="80" Margin="0,0,16,0" AutomationProperties.Name="Zamanlama Saati" />
                                    <TextBlock Text="Dakika:" VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <ComboBox x:Name="ScheduleMinuteBox" Width="80" Margin="0,0,16,0" AutomationProperties.Name="Zamanlama Dakikası" />
                                    <Button Content="_Zamanlamayı Oluştur" Margin="0,0,8,0" Padding="8" Click="CreateSchedule_Click" />
                                    <Button Content="Z_amanlamayı Sil" Padding="8" Click="DeleteSchedule_Click" />
                                </WrapPanel>
                                <TextBlock x:Name="ScheduleStatusText" Margin="0,8,0,0" FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>

                        <Border x:Name="DiagnosticsBorder" CornerRadius="10" Padding="14">
                            <StackPanel>
                                <TextBlock Text="Ek Tanılama" FontSize="24" FontWeight="Bold" />
                                <WrapPanel Margin="0,10,0,0" ItemHeight="42" ItemWidth="250">
                                    <Button Content="_Ön Uçuş Kontrolü" Margin="0,0,8,8" Padding="8" Click="RunPreflightCheck_Click" />
                                    <Button Content="Baş_langıç Raporu" Margin="0,0,8,8" Padding="8" Click="GenerateStartupReport_Click" />
                                    <Button Content="_Servis Sağlığı" Margin="0,0,8,8" Padding="8" Click="AnalyzeCriticalServices_Click" />
                                    <Button Content="_Olay Günlüğü Özeti" Margin="0,0,8,8" Padding="8" Click="GenerateEventLogSummary_Click" />
                                </WrapPanel>
                                <TextBox x:Name="PreflightOutputBox" Height="160" IsReadOnly="True" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" FontFamily="Consolas" AutomationProperties.Name="Ön uçuş ve ek tanılama çıktı alanı" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border x:Name="ReportsPanel" Grid.Row="1" Visibility="Collapsed" CornerRadius="12" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border x:Name="ReportConfigBorder" CornerRadius="10" Padding="14" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Rapor Ayarları" FontSize="24" FontWeight="Bold" />
                            <TextBlock Margin="0,10,0,4" Text="Rapor Başlığı" />
                            <TextBox x:Name="ReportTitleBox" Text="Temizlik ve Bakım Raporu v3" AutomationProperties.Name="Rapor Başlığı" />
                            <CheckBox x:Name="IncludeSystemSnapshotInReport" Margin="0,8,0,0" IsChecked="True" Content="Rapora sistem özetini ekle" />
                            <WrapPanel Margin="0,10,0,0" ItemHeight="42" ItemWidth="220">
                                <Button Content="_JSON Raporu Üret" Margin="0,0,8,0" Padding="8" Click="SaveJsonReportButton_Click" />
                                <Button Content="_Acil Paket Oluştur" Padding="8" Click="CreateEmergencySupportPackage_Click" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border x:Name="ReportInfoBorder" Grid.Row="1" CornerRadius="10" Padding="14" Margin="0,0,0,10">
                        <TextBlock x:Name="LastReportPathText" Text="Henüz rapor oluşturulmadı." TextWrapping="Wrap" />
                    </Border>

                    <Border x:Name="ReportPreviewBorder" Grid.Row="2" CornerRadius="10" Padding="14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                                <TextBlock Text="Rapor Önizlemesi" FontSize="24" FontWeight="Bold" />
                            <TextBox x:Name="ReportPreviewBox" Grid.Row="1" Margin="0,10,0,0" IsReadOnly="True" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" FontFamily="Consolas" AutomationProperties.Name="Rapor önizlemesi" />
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border x:Name="AccessibilityPanel" Grid.Row="1" Visibility="Collapsed" CornerRadius="12" Padding="12">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border x:Name="AccessibilityBorder" CornerRadius="10" Padding="14" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="Erişilebilirlik ve WCAG AAA" FontSize="24" FontWeight="Bold" />
                                <TextBlock Margin="0,10,0,4" Text="Yazı Boyutu" />
                                <Slider x:Name="FontScaleSlider" Minimum="14" Maximum="34" Value="18" TickFrequency="1" IsSnapToTickEnabled="True" AutomationProperties.Name="Yazı Boyutu Kaydırıcısı" />
                                <CheckBox x:Name="HighContrastModeCheck" Margin="0,10,0,0" Content="Yüksek kontrast modu (sadece uygulama)" />
                                <CheckBox x:Name="ScreenReaderAnnouncementsCheck" Margin="0,6,0,0" IsChecked="True" Content="Ekran okuyucu canlı anonslarını etkin tut" />
                                <WrapPanel Margin="0,12,0,0" ItemHeight="42" ItemWidth="220">
                                    <Button Content="_Ayarları Uygula" Margin="0,0,8,0" Padding="8" Click="ApplyAccessibility_Click" />
                                    <Button Content="_Varsayılana Dön" Padding="8" Click="ResetAccessibility_Click" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border x:Name="WcagBorder" CornerRadius="10" Padding="14">
                            <StackPanel>
                                <TextBlock Text="Kontrast Doğrulama" FontSize="24" FontWeight="Bold" />
                                <TextBlock x:Name="ContrastInfoText" Margin="0,10,0,0" TextWrapping="Wrap" />
                                <Button Margin="0,10,0,0" Width="260" Content="_WCAG AAA Kontrolünü Yenile" Click="RefreshContrastAudit_Click" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border x:Name="TributePanel" Grid.Row="1" Visibility="Collapsed" CornerRadius="12" Padding="12">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border x:Name="TributeInfoBorder" CornerRadius="10" Padding="14" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="Olcay Aşçı Anısına" FontSize="24" FontWeight="Bold" />
                                <TextBlock x:Name="ResearchSummaryText" Margin="0,10,0,0" TextWrapping="Wrap" />
                                <TextBlock Margin="0,12,0,4" Text="Uzun İthaf Metni" FontWeight="SemiBold" />
                                <TextBox x:Name="TributeLongNarrativeBox" Height="210" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" AutomationProperties.Name="Uzun ithaf metni" />
                                <TextBlock Margin="0,12,0,4" Text="Kaynaklar" FontWeight="SemiBold" />
                                <ListBox x:Name="SourceList" Height="150" AutomationProperties.Name="Kaynaklar Listesi">
                                    <ListBoxItem Content="https://tr.linkedin.com/in/olcay-a%C5%9F%C3%A7%C4%B1-b0a619124" />
                                    <ListBoxItem Content="https://tr.linkedin.com/posts/olcay-a%C5%9F%C3%A7%C4%B1-b0a619124_eri%C5%9Filelilirlik-kavram%C4%B1n%C4%B1-ve-evrensel-tasar%C4%B1m%C4%B1-activity-6665135484022337536-UicK" />
                                    <ListBoxItem Content="https://tr.linkedin.com/posts/olcay-a%C5%9F%C3%A7%C4%B1-b0a619124_nvda-20203ten-m%C3%BCjdeler-activity-6704406346390888448-1cmP" />
                                    <ListBoxItem Content="https://eniyideneyim.com/" />
                                </ListBox>
